# Copy to .env and fill in. .env is gitignored.

# Required: Groq free-tier API key (https://console.groq.com)
GROQ_API_KEY=

# Optional: enables the Anthropic provider only when set. Leave blank to run on Groq alone.
ANTHROPIC_API_KEY=

# Role -> model mapping (override to swap models without code changes)
PLANNER_MODEL=openai/gpt-oss-120b
EXECUTOR_MODEL=llama-3.1-8b-instant

# Guardrails
MAX_ITERATIONS=10
MAX_TOOL_CALLS=20
